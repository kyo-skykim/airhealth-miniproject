# ---------------------------------------------------------------------------
# AirHealth configuration (Databricks). Copy to `.env` and adjust.
# The warehouse + transforms + models run on Databricks; ingestion can run
# anywhere (sample mode needs no accounts).
# ---------------------------------------------------------------------------

# Ingestion mode: "sample" (synthetic, offline, default) or "api" (live extractors).
INGEST_MODE=sample

# Landing zone for ingested parquet. Locally this is ./data; on a Databricks
# cluster set it to the bronze Unity Catalog volume:
#   DATA_DIR=/Volumes/airhealth/bronze/landing
DATA_DIR=./data

# Geographic + time scope (kept small so volumes stay sane).
# Comma-separated metro keys defined in ingestion/common/locations.py
METROS=los_angeles,new_york,chicago,houston,phoenix
START_DATE=2023-01-01
END_DATE=2023-12-31

# --- Live API settings (only needed when INGEST_MODE=api) ---
OPENAQ_API_KEY=
CENSUS_API_KEY=

# --- Databricks (Unity Catalog + Delta, medallion schemas) ---
DBX_CATALOG=airhealth
DBX_BRONZE_SCHEMA=bronze
DBX_SILVER_SCHEMA=silver
DBX_GOLD_SCHEMA=gold
DBX_VOLUME=landing

# --- Databricks connection (dbt-databricks + the Streamlit dashboard) ---
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
