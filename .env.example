# ---------------------------------------------------------------------------
# AirHealth configuration. Copy to `.env` and adjust. The whole pipeline runs
# locally with zero external accounts using the defaults below (BACKEND=duckdb,
# INGEST_MODE=sample).
# ---------------------------------------------------------------------------

# Warehouse backend: "duckdb" (local, default) or "bigquery" (cloud).
BACKEND=duckdb

# Ingestion mode: "sample" (synthetic, offline, default) or "api" (live extractors).
INGEST_MODE=sample

# Local data + warehouse locations (used when BACKEND=duckdb).
DATA_DIR=./data
DUCKDB_PATH=./data/warehouse.duckdb

# Geographic + time scope (kept small so volumes stay sane).
# Comma-separated metro keys defined in ingestion/common/locations.py
METROS=los_angeles,new_york,chicago,houston,phoenix
START_DATE=2023-01-01
END_DATE=2023-12-31

# --- Live API settings (only needed when INGEST_MODE=api) ---
OPENAQ_API_KEY=
CENSUS_API_KEY=

# --- Cloud settings (only needed when BACKEND=bigquery) ---
GCP_PROJECT=
GCS_BUCKET=
BQ_DATASET_RAW=airhealth_raw
BQ_DATASET_ANALYTICS=airhealth_analytics
BQ_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=
